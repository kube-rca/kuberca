{
  "include-v-in-tag": false,
  "separate-pull-requests": true,
  "packages": {
    "backend": {
      "release-type": "go",
      "component": "backend",
      "extra-files": ["backend/VERSION"],
      "changelog-path": "backend/CHANGELOG.md"
    },
    "frontend": {
      "release-type": "node",
      "component": "frontend",
      "changelog-path": "frontend/CHANGELOG.md"
    },
    "agent": {
      "release-type": "python",
      "component": "agent",
      "changelog-path": "agent/CHANGELOG.md"
    },
    "charts/kube-rca": {
      "release-type": "helm",
      "component": "helm-chart",
      "changelog-path": "charts/kube-rca/CHANGELOG.md"
    }
  }
}
